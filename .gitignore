# ---------------------------------------------------------------
# Stripe Availability Condition — .gitignore
# ---------------------------------------------------------------

# Node / Grunt (only needed locally to rebuild amd/build/)
node_modules/
npm-debug.log*
grunt-debug.log*
build-amd.js
moodle_plugin_standards.txt
vendor
# Composer lock (not needed because vendor is bundled)
composer.lock
# Ignore Stripe example README (contains test API keys triggering GitHub scan)
vendor/stripe/stripe-php/README.md
# ---------------------------------------------------------------
# IDE / editor directories
# ---------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.buildpath
.settings/

# ---------------------------------------------------------------
# OS-generated junk
# ---------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
settings.local.json
# ---------------------------------------------------------------
# Release artefacts — built locally, not committed
# ---------------------------------------------------------------
*.zip
*.tar.gz

# ---------------------------------------------------------------
# Local dev / test config (never commit real API keys)
# ---------------------------------------------------------------
.env
.env.*
config.local.php

# ---------------------------------------------------------------
# PHPUnit / test coverage
# ---------------------------------------------------------------
coverage/
phpunit.xml